#let accent = rgb(30, 64, 175)

#set page(paper: "a4", margin: (top: 1.5cm, bottom: 1.5cm, left: 1.8cm, right: 1.8cm))
#set text(font: "Libertinus Sans", size: 10pt)
#set par(justify: false)
#set list(indent: 1.5em, spacing: 1pt)

#show heading.where(level: 1): it => [
  #v(10pt, weak: true)
  #block(below: 4pt, width: 100%)[
    #text(fill: accent, size: 12pt, weight: "bold")[#it.body]
    #v(2pt, weak: true)
    #line(length: 100%, stroke: (paint: accent, thickness: 0.5pt))
  ]
]

= Profile
{{ summary }}

{% if experience and experience | length > 0 %}
= Experience

{% for job in experience %}
#grid(columns: (1fr, auto), align: (left + top, right + top),
  [*{{ job.role }}*], [#text(size: 9pt)[_{{ job.start_date }} -- {{ job.end_date }}_]],
  [#text(fill: accent)[_{{ job.company }}_]], [],
)
{% for bullet in job.bullets %}
- {{ bullet }}
{% endfor %}
{% if not loop.last %}
#v(4pt)
{% endif %}
{% endfor %}
{% endif %}
{% if skills.languages or skills.frameworks or skills.tools %}
= Skills

#grid(columns: (auto, 1fr), column-gutter: 0.8em, row-gutter: 0.3em,
{% if skills.languages %}
  [*Languages*], [{{ skills.languages | join(" • ") }}],
{% endif %}
{% if skills.frameworks %}
  [*Frameworks*], [{{ skills.frameworks | join(" • ") }}],
{% endif %}
{% if skills.tools %}
  [*Tools*], [{{ skills.tools | join(" • ") }}],
{% endif %}
)
{% endif %}
{% if education and education | length > 0 %}
= Education

{% for edu in education %}
#grid(columns: (1fr, auto), align: (left + top, right + top),
  [*{{ edu.institution }}*], [#text(size: 9pt)[_{{ edu.year }}_]],
  [_{{ edu.degree }}_], [],
)
{% if not loop.last %}
#v(4pt)
{% endif %}
{% endfor %}
{% endif %}
{% if credentials and credentials | length > 0 %}
= Credentials

{% for c in credentials %}
- {{ c }}
{% endfor %}
{% endif %}
